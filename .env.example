# =============================================================================
# .env.example — Docker 環境變數範本
# 複製為 .env 後依需求修改：
#   cp .env.example .env
# =============================================================================

# GitHub Personal Access Token（用於容器內 git push 私有 repo）
# 取得：https://github.com/settings/tokens
GITHUB_TOKEN=

# Docker 映像 tag（預設 latest）
# IMAGE_TAG=latest

# 時區（預設 Asia/Taipei）
# TZ=Asia/Taipei
